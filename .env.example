# Copy this file to .env and fill in the values
#
# Usage:
#   cp .env.example .env
#   # fill in all values below
#   docker compose up --build             # main branch (local Kong)
#   docker compose -f docker-compose-serverless.yml up --build -d   # serverless branch

# ══════════════════════════════════════════════════════════════════════════════
# MAIN BRANCH — Local Kong Gateway + Guardrail Service
# ══════════════════════════════════════════════════════════════════════════════

# ── Kong Gateway Enterprise License ──────────────────────────────────────────
# Required for ai-custom-guardrail plugin (Kong Enterprise 3.14+).
# Paste the full JSON license string (single line, no newlines).
KONG_LICENSE_DATA=

# ── Ollama (host machine) ─────────────────────────────────────────────────────
# Ollama must be running on the host before starting Docker Compose.
#
#   brew install ollama        (macOS)
#   ollama serve               # start Ollama
#   ollama pull llama3.2       # download the model (~2 GB)
#
# The Docker containers reach Ollama via host.docker.internal:11434.
# No configuration needed here — it is hardcoded in kong.yaml.

# ══════════════════════════════════════════════════════════════════════════════
# SERVERLESS-GW BRANCH — Konnect Serverless + MCP + OPA
# ══════════════════════════════════════════════════════════════════════════════

# ── Konnect ───────────────────────────────────────────────────────────────────
# Personal Access Token from https://cloud.konghq.com → Account → Personal Access Tokens
KONNECT_TOKEN=

# Serverless control plane name (visible in Konnect dashboard → Gateway Manager)
KONNECT_CP_NAME=serverless-default

# Proxy URL of the Serverless GW (shown in Konnect dashboard → Gateway Manager → Overview)
# Example: https://abc123.us.serverless.konghq.com
KONNECT_PROXY_URL=

# ── ngrok tunnels ─────────────────────────────────────────────────────────────
# Run:  ngrok start --all --config ngrok-serverless.yml
# Then paste the HTTPS URLs assigned by ngrok.
MCP_SERVER_NGROK_URL=https://

# Guardrail Service / PDP (local port 8080) — HOSTNAME ONLY (no https://, no trailing slash)
# Example: abc123.ngrok-free.app
GUARDRAIL_NGROK_HOST=


