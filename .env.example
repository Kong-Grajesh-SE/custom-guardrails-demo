# Copy this file to .env and fill in the values.
# The setup.sh script fills this in automatically — copy manually only
# if you prefer a manual setup.
#
#   cp .env.example .env
#   # edit .env with your values
#   ./setup.sh --yes    # or run services manually (see README.md)

# ══════════════════════════════════════════════════════════════════════════════
# Konnect Serverless Gateway
# ══════════════════════════════════════════════════════════════════════════════

# Personal Access Token — https://cloud.konghq.com → Account → Personal Access Tokens
KONNECT_TOKEN=

# Serverless control plane name (Konnect dashboard → Gateway Manager)
KONNECT_CP_NAME=serverless-default

# Proxy URL of the Serverless GW (Konnect dashboard → Gateway Manager → Overview)
# Example: https://abc123.us.serverless.konghq.com
KONNECT_PROXY_URL=

# ══════════════════════════════════════════════════════════════════════════════
# ngrok
# ══════════════════════════════════════════════════════════════════════════════

# Your ngrok authtoken — https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# MCP Server tunnel (local port 8090) — full HTTPS URL
# Example: https://abc123.ngrok-free.app
MCP_SERVER_NGROK_URL=

# Guardrail Service / PDP tunnel (local port 8080) — HOSTNAME ONLY (no https://, no trailing slash)
# Example: abc123.ngrok-free.app
GUARDRAIL_NGROK_HOST=

