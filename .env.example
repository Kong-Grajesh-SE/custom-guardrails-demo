# Copy this file to .env and fill in the values
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
#   ./startup.sh

# ── Mistral AI API Key ───────────────────────────────────────────────────────
# Get your API key from https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── Mistral Model ────────────────────────────────────────────────────────────
# Available: mistral-small-latest, mistral-medium-latest, mistral-large-latest
MISTRAL_MODEL=mistral-small-latest

# ── Guardrail Service URL (as seen by Kong) ──────────────────────────────────
# If Kong and the guardrail service are on the same machine: http://localhost:8080
# If Kong is remote, use your machine's public IP/hostname: http://<your-ip>:8088
GUARDRAIL_URL=http://localhost:8088

# ── Kong Gateway Proxy URL (for testing) ─────────────────────────────────────
KONG_PROXY_URL=http://localhost:8000
# The Docker containers reach Ollama via host.docker.internal:11434.
# No configuration needed here — it's hardcoded in kong.yaml.
