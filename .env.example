# Copy this file to .env and fill in the values
#
# Usage:
#   cp .env.example .env
#   # edit .env with your license
#   docker compose up --build

# ── Kong Gateway Enterprise License ──────────────────────────────────────────
# The AI Custom Guardrail plugin requires Kong Gateway Enterprise (3.14+).
# Obtain your license from https://konghq.com or via Konnect.
# Paste the full JSON license string here (single line, no newlines).
KONG_LICENSE_DATA=

# ── Ollama (host machine) ─────────────────────────────────────────────────────
# Ollama must be running on the host before starting Docker Compose.
#
#   brew install ollama        (macOS)
#   ollama serve               # start Ollama
#   ollama pull llama3.2       # download the model (~2 GB)
#
# The Docker containers reach Ollama via host.docker.internal:11434.
# No configuration needed here — it's hardcoded in kong.yaml.
